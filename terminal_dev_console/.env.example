# Required on Vercel for persistent accounts, settings, sessions, and projects.
# Vercel Marketplace may create either the STORAGE_* names or the UPSTASH_* names.
STORAGE_KV_REST_API_URL=
STORAGE_KV_REST_API_TOKEN=

# Manual Upstash setups usually use these names instead.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
